# Accountify backend (Django API)
ACCOUNTIFY_BASE_URL=http://localhost:8000
ACCOUNTIFY_USERNAME=your_username
ACCOUNTIFY_PASSWORD=your_password
# Optional: if unset, the bot picks the first entity returned by /api/entities/
ACCOUNTIFY_ENTITY_ID=

# Shared secret the iPhone Shortcut sends in X-Bot-Secret header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_SHARED_SECRET=replace_with_random_token

# Bot HTTP server
BOT_HOST=127.0.0.1
BOT_PORT=8787
